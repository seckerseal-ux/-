AI_PROVIDER=openai
OPENAI_BASE_URL=https://aihubmix.com/v1
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
AIHUBMIX_API_KEY=replace-with-your-real-key
OPENAI_API_KEY=replace-with-your-real-key
OPENAI_TRANSCRIBE_MODEL=gemini-3-flash-preview-free
OPENAI_REVIEW_MODEL=gemini-3-flash-preview-free
OPENAI_WRITING_REVIEW_MODEL=gemini-3-flash-preview-free
BACKEND_STORAGE_DIR=/tmp/ielts-lexicon-sprint-data

# Optional: switch cloud sync from local sqlite to Upstash Redis REST.
# CLOUD_SYNC_BACKEND=upstash
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=replace-with-your-upstash-rest-token
# UPSTASH_KEY_PREFIX=ielts-lexicon-sprint
# CLOUD_SESSION_SECRET=replace-with-a-long-random-secret
